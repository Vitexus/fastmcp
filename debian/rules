#!/usr/bin/make -f

export PYBUILD_NAME=fastmcp

# The real "fastmcp" package lives in the fastmcp_slim/ workspace member;
# the root pyproject.toml is just upstream's thin meta-package.
%:
	dh $@ --with python3 --buildsystem=pybuild --sourcedirectory=fastmcp_slim

override_dh_auto_configure:
	# Backup original pyproject.toml
	cp fastmcp_slim/pyproject.toml fastmcp_slim/pyproject.toml.orig
	# Patch pyproject.toml to use a static version and dependency list
	# instead of uv-dynamic-versioning / hatch optional-dependency hooks
	python3 debian/patch-pyproject.py fastmcp_slim/pyproject.toml 3.4.2
	dh_auto_configure

override_dh_auto_test:
	# Skip tests - test dependencies are not packaged in Debian

override_dh_auto_clean:
	dh_auto_clean
	# Restore original pyproject.toml if backup exists
	[ ! -f fastmcp_slim/pyproject.toml.orig ] || mv fastmcp_slim/pyproject.toml.orig fastmcp_slim/pyproject.toml
